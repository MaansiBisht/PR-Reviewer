    "husky": "^8.0.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "simple-git": "^3.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
