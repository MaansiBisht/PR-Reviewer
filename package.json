{
  "name": "pr-reviewer",
  "version": "1.0.0",
  "description": "Local AI-powered Git PR reviewer using Ollama",
  "main": "dist/index.js",
  "bin": {
    "pr-review": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "prepare": "husky install"
  },
  "keywords": [
