{
  "name": "pr-reviewer",
  "version": "2.0.0",
  "description": "Multi-agent AI-powered PR reviewer with GitHub/Bitbucket integration",
  "main": "dist/index.js",
  "bin": {
    "pr-review": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "server": "ts-node src/server/index.ts",
    "ui": "cd web && npm run dev",
    "ui:build": "cd web && npm run build",
    "lint": "eslint src/**/*.ts",
    "prepare": "husky install"
  },
  "keywords": [
    "git",
    "code-review",
    "ai",
    "ollama",
    "cli",
    "multi-agent",
    "github",
    "bitbucket"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "husky": "^8.0.3",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "openai": "^6.35.0",
    "simple-git": "^3.21.0",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
