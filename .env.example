# ─── LLM Provider ───────────────────────────────────────────────────────────
# Choose one: ollama | claude | openai
LLM_PROVIDER=ollama

# Ollama (local) — used when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Cloud — used when LLM_PROVIDER=claude or openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLOUD_MODEL=claude-opus-4-7   # or gpt-4o

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Personal Access Token — scopes: repo, read:user
GITHUB_TOKEN=

# ─── Bitbucket ───────────────────────────────────────────────────────────────
# App password — permissions: Repositories (read), Pull requests (read)
BITBUCKET_TOKEN=
BITBUCKET_USERNAME=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Deployment (Contabo VPS) ─────────────────────────────────────────────────
# Your domain pointed at the VPS — used in nginx/nginx.conf server_name
# DOMAIN=pr-reviewer.yourdomain.com
